# Kaggle API credentials
# https://www.kaggle.com/settings > API > Create New Token
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# GCP settings
GCP_PROJECT_ID=clickstream-pipeline-484705
GCP_BUCKET_NAME=clickstream-pipeline-484705-clickstream-data
GCP_LOCATION=US

# Slack Webhook URL (error alerts)
# Setup: https://api.slack.com/messaging/webhooks
# 1. Go to https://api.slack.com/apps → Create New App → From scratch
# 2. Enable Incoming Webhooks → Add New Webhook to Workspace
# 3. Select notification channel → Copy Webhook URL
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
